              <size>1.5 0.15 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1.5 0.15 1.0</size>
            </box>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="obs_q3_small_box">
      <static>true</static>
      <pose>-1.5 -3.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
