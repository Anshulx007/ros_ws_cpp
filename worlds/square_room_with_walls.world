      <pose>3.25 0.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>3.5 0.15 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>3.5 0.15 1.0</size>
            </box>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="inner_horizontal_west">
      <static>true</static>
      <pose>-3.25 0.0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>3.5 0.15 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>3.5 0.15 1.0</size>
            </box>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="obs_q1_pillar">
