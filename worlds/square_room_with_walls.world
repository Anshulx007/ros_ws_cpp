      <pose>2.5 2.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1.0 1.0 1.0</size>
            </box>
          </geometry>
        </visual>
      </link>
    </model>

    <model name="obs_q2_wall">
      <static>true</static>
      <pose>-2.5 2.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
